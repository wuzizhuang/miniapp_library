page {
  min-height: 100vh;
  background: #f4efe6;
  color: #1f1a14;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.page-shell {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 28rpx;
}

.hero-card {
  background: linear-gradient(160deg, #123c38 0%, #0d8a72 70%, #68b8a0 100%);
  color: #ffffff;
  border-radius: 28rpx;
  padding: 32rpx;
  box-shadow: 0 20rpx 48rpx rgba(13, 138, 114, 0.18);
  margin-bottom: 24rpx;
}

.hero-title {
  font-size: 46rpx;
  font-weight: 700;
  line-height: 1.25;
}

.hero-subtitle {
  margin-top: 12rpx;
  font-size: 28rpx;
  line-height: 1.65;
  color: rgba(255, 255, 255, 0.82);
}

.panel {
  background: #fffaf2;
  border: 1rpx solid #ddceb8;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 18rpx;
}

.muted-text {
  color: #6f6559;
  font-size: 26rpx;
  line-height: 1.7;
}

.danger-text {
  color: #b54035;
  font-size: 26rpx;
  line-height: 1.7;
}

.button-row {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.button-primary,
.button-secondary,
.button-danger,
.button-ghost {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 80rpx;
  padding: 0 28rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.button-primary {
  background: #0d8a72;
  color: #ffffff;
}

.button-secondary {
  background: #efe4d2;
  color: #1f1a14;
}

.button-danger {
  background: #b54035;
  color: #ffffff;
}

.button-ghost {
  background: #ffffff;
  color: #0d8a72;
  border: 1rpx solid #8cc7b7;
}

.chip-row {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.chip,
.chip-primary,
.chip-warning,
.chip-danger,
.chip-success {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  line-height: 1;
}

.chip {
  background: #efe4d2;
  color: #1f1a14;
}

.chip-primary {
  background: #dff4ee;
  color: #0d6e5c;
}

.chip-warning {
  background: #fff0d8;
  color: #bb7a2b;
}

.chip-danger {
  background: #f8ddd7;
  color: #b54035;
}

.chip-success {
  background: #e4f6ec;
  color: #2e8050;
}

.stat-grid,
.card-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.stat-card {
  border-radius: 20rpx;
  background: #f8f1e5;
  padding: 20rpx;
}

.stat-value {
  color: #123c38;
  font-size: 42rpx;
  font-weight: 700;
}

.stat-label {
  margin-top: 8rpx;
  color: #6f6559;
  font-size: 24rpx;
}

.list-card {
  display: flex;
  gap: 20rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #efe4d2;
}

.list-card:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.book-cover {
  width: 140rpx;
  height: 196rpx;
  border-radius: 20rpx;
  background: #e7dcc9;
  flex-shrink: 0;
}

.book-cover--small {
  width: 108rpx;
  height: 148rpx;
}

.book-info {
  flex: 1;
  min-width: 0;
}

.book-title {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.35;
}

.book-meta {
  margin-top: 8rpx;
  color: #6f6559;
  font-size: 25rpx;
  line-height: 1.6;
}

.search-input,
.text-input,
.textarea {
  width: 100%;
  background: #ffffff;
  border: 1rpx solid #ddceb8;
  border-radius: 18rpx;
  box-sizing: border-box;
  color: #1f1a14;
}

.search-input,
.text-input {
  min-height: 82rpx;
  padding: 0 22rpx;
}

.textarea {
  min-height: 180rpx;
  padding: 18rpx 22rpx;
}

.inline-actions {
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.toolbar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex-wrap: wrap;
}

.toolbar-spread {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  flex-wrap: wrap;
}

.field-stack {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.field-label {
  font-size: 26rpx;
  color: #6f6559;
}

.section-subtitle {
  margin-top: -8rpx;
  margin-bottom: 18rpx;
  color: #6f6559;
  font-size: 24rpx;
}

.entry-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.entry-card {
  background: #f8f1e5;
  border-radius: 20rpx;
  padding: 22rpx;
}

.entry-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #123c38;
}

.entry-desc {
  margin-top: 8rpx;
  color: #6f6559;
  font-size: 24rpx;
  line-height: 1.6;
}

.pill-switch {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.pill-item {
  padding: 14rpx 24rpx;
  border-radius: 999rpx;
  background: #efe4d2;
  color: #6f6559;
  font-size: 26rpx;
}

.pill-item--active {
  background: #123c38;
  color: #ffffff;
}

.summary-row {
  display: flex;
  gap: 16rpx;
  overflow-x: auto;
  padding-bottom: 8rpx;
}

.summary-item {
  min-width: 208rpx;
  background: rgba(255, 255, 255, 0.14);
  border-radius: 20rpx;
  padding: 18rpx 20rpx;
  box-sizing: border-box;
}

.summary-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.76);
}

.summary-value {
  margin-top: 10rpx;
  font-size: 38rpx;
  font-weight: 700;
}

.cover-hero {
  display: flex;
  gap: 24rpx;
}

.cover-hero .book-cover {
  width: 188rpx;
  height: 268rpx;
}

.meta-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.meta-item {
  color: #4b4339;
  font-size: 25rpx;
  line-height: 1.7;
}

.divider {
  height: 1rpx;
  background: #efe4d2;
  margin: 22rpx 0;
}

.empty-card {
  border-radius: 20rpx;
  background: #f8f1e5;
  color: #6f6559;
  font-size: 26rpx;
  line-height: 1.7;
  padding: 24rpx;
}

.feed-card {
  background: #fffaf2;
  border: 1rpx solid #ddceb8;
  border-radius: 22rpx;
  padding: 24rpx;
  margin-bottom: 18rpx;
}

.feed-header {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.feed-author {
  font-size: 30rpx;
  font-weight: 700;
}

.feed-meta {
  color: #6f6559;
  font-size: 24rpx;
  line-height: 1.6;
}

.feed-content {
  color: #1f1a14;
  font-size: 27rpx;
  line-height: 1.8;
}

.notice-card {
  border-radius: 20rpx;
  padding: 22rpx;
  border: 1rpx solid #ddceb8;
  background: #fffaf2;
  margin-bottom: 16rpx;
}

.notice-card--unread {
  background: #f3fbf8;
  border-color: #9ad0c1;
}

.notice-card--highlight,
.feed-card--highlight,
.list-card--highlight {
  background: #eef9f4;
  border-color: #89c7b3;
  box-shadow: 0 10rpx 30rpx rgba(13, 138, 114, 0.1);
}

.notice-title {
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.4;
}

.notice-content {
  margin-top: 10rpx;
  color: #4b4339;
  font-size: 26rpx;
  line-height: 1.8;
}

.notice-meta {
  margin-top: 12rpx;
  color: #6f6559;
  font-size: 22rpx;
}

.amount-text {
  color: #123c38;
  font-size: 40rpx;
  font-weight: 700;
}

.tag-outline {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid #d4c3ab;
  color: #6f6559;
  font-size: 23rpx;
}

.rating-row {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.rating-pill {
  min-width: 84rpx;
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: #efe4d2;
  color: #6f6559;
  font-size: 24rpx;
  line-height: 1;
  text-align: center;
  box-sizing: border-box;
}

.rating-pill--active {
  background: #123c38;
  color: #ffffff;
}

.card-note {
  margin-top: 12rpx;
  color: #6f6559;
  font-size: 24rpx;
  line-height: 1.6;
}

/* ===== Active / press-down feedback ===== */

.button-primary:active {
  background: #0a6f5c;
}

.button-secondary:active {
  background: #e2d5c1;
}

.button-danger:active {
  background: #9c362c;
}

.button-ghost:active {
  background: #f0faf6;
}

.pill-item:active {
  opacity: 0.7;
}

.pill-item--active:active {
  opacity: 0.85;
}

.list-card:active {
  background: #f5efe4;
}

.notice-card:active {
  background: #f7f1e7;
}

.feed-card:active {
  background: #f7f1e7;
}

.entry-card:active {
  background: #efe5d5;
}

.chip:active,
.chip-primary:active,
.chip-warning:active,
.chip-danger:active,
.chip-success:active {
  opacity: 0.7;
}

.stat-card:active {
  background: #f0e8d9;
}
