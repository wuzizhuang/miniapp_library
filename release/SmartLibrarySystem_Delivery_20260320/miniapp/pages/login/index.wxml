<scroll-view class="page-shell" scroll-y>
  <view class="hero-card">
    <view class="hero-title">智慧图书馆</view>
    <view class="hero-subtitle">使用你的读者账号登录</view>
    <view wx:if="{{autoLoginEnabled}}" class="login-notice">
      已开启默认自动登录。当前默认联调账号：{{username}} / {{password}}
    </view>
  </view>

  <view class="panel">
    <view class="section-title">读者登录</view>
    <view class="field-stack">
      <view class="field-label">用户名</view>
      <input
        class="text-input"
        placeholder="请输入用户名"
        value="{{username}}"
        bindinput="onUsernameInput"
      />

      <view class="field-label">密码</view>
      <input
        class="text-input"
        password
        placeholder="请输入密码"
        value="{{password}}"
        bindinput="onPasswordInput"
      />

      <view wx:if="{{errorMessage}}" class="danger-text">{{errorMessage}}</view>

      <view class="button-primary login-submit-button" bindtap="onSubmit">
        {{loading ? '登录中...' : '立即登录'}}
      </view>
    </view>
  </view>

  <view class="panel">
    <view class="section-title">其他操作</view>
    <view class="button-row">
      <view class="button-ghost" bindtap="goRegister">注册账号</view>
      <view class="button-ghost" bindtap="goForgotPassword">找回密码</view>
    </view>
  </view>
</scroll-view>
