# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# ─── MySQL ───────────────────────────────
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=library_management
MYSQL_USER=library_user
MYSQL_PASSWORD=library_pass

# ─── 后端配置 ─────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# JWT 密钥：必须是 Base64 编码后的随机长字符串（至少 32 字节）
JWT_SECRET=MDEyMzQ1Njc4OWFiY2RlZjAxMjM0NTY3ODlhYmNkZWY=
APP_FRONTEND_BASE_URL=http://localhost:3000
APP_SECURITY_REDIS_ENABLED=true
APP_CACHE_REDIS_ENABLED=true
APP_CACHE_HOT_KEYWORDS_TTL=PT2M
APP_CACHE_DASHBOARD_STATS_TTL=PT30S
APP_CACHE_DASHBOARD_ANALYTICS_TTL=PT45S
APP_AI_ENABLED=false
APP_AI_PROVIDER=openai
APP_AI_OPENAI_BASE_URL=https://api.openai.com/v1
# APP_AI_OPENAI_API_KEY=
APP_AI_OPENAI_MODEL=gpt-4.1-mini
APP_AI_OPENAI_MAX_OUTPUT_TOKENS=700
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
# SPRING_DATA_REDIS_PASSWORD=

# ─── 其他（可选）────────────────────────
# JPA_DDL_AUTO=validate  # update / validate / none
# JPA_SHOW_SQL=false
