.picker-stack {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.picker-field {
  width: 100%;
  min-height: 82rpx;
  padding: 20rpx 22rpx;
  background: #ffffff;
  border: 1rpx solid #ddceb8;
  border-radius: 18rpx;
  box-sizing: border-box;
  color: #1f1a14;
  line-height: 1.5;
}

.field-helper-text {
  color: #6f6559;
  font-size: 24rpx;
  line-height: 1.6;
}
