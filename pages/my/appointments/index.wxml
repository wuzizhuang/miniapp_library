<scroll-view class="page-shell" scroll-y>
  <view class="panel">
    <view class="section-title">新建服务预约</view>
    <view class="field-stack">
      <view class="field-label">服务类型</view>
      <view class="chip-row">
        <view
          wx:for="{{serviceOptions}}"
          wx:key="value"
          class="pill-item {{serviceType === item.value ? 'pill-item--active' : ''}}"
          data-value="{{item.value}}"
          bindtap="pickService"
        >
          {{item.label}}
        </view>
      </view>

      <view class="field-label">办理方式</view>
      <view class="chip-row">
        <view
          wx:for="{{methodOptions}}"
          wx:key="value"
          class="pill-item {{method === item.value ? 'pill-item--active' : ''}}"
          data-value="{{item.value}}"
          bindtap="pickMethod"
        >
          {{item.label}}
        </view>
      </view>

      <view class="field-label">预约时间</view>
      <input class="text-input" value="{{scheduledTime}}" data-field="scheduledTime" bindinput="onFieldInput" />

      <view class="field-label">关联图书</view>
      <input class="text-input" value="{{bookTitle}}" data-field="bookTitle" bindinput="onFieldInput" placeholder="可选，填写图书名" />

      <view class="field-label">备注</view>
      <textarea class="textarea" value="{{notes}}" data-field="notes" bindinput="onFieldInput"></textarea>

      <view class="button-primary" bindtap="createAppointment">{{submitting ? '提交中...' : '提交预约'}}</view>
    </view>
  </view>

  <view class="panel">
    <view class="section-title">我的服务预约</view>
    <view wx:if="{{loading}}" class="empty-card">正在加载服务预约...</view>
    <view wx:elif="{{errorMessage}}" class="empty-card danger-text">{{errorMessage}}</view>
    <view wx:elif="{{!items.length}}" class="empty-card">当前没有服务预约记录。</view>

    <view wx:for="{{items}}" wx:key="appointmentId" class="notice-card">
      <view class="toolbar-spread">
        <view class="notice-title">{{item.serviceLabel}}</view>
        <view class="{{item.statusClass}}">{{item.statusLabel}}</view>
      </view>
      <view class="notice-content">方式：{{item.methodLabel}}</view>
      <view class="notice-content">时间：{{item.timeLabel}}</view>
      <view wx:if="{{item.bookTitle}}" class="notice-content">图书：{{item.bookTitle}}</view>
      <view wx:if="{{item.notes}}" class="notice-content">备注：{{item.notes}}</view>
      <view wx:if="{{item.status === 'PENDING'}}" class="inline-actions">
        <view class="button-secondary" bindtap="cancelAppointment" data-appointment-id="{{item.appointmentId}}">取消预约</view>
      </view>
    </view>
  </view>
</scroll-view>
