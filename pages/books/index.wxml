<scroll-view class="page-shell" scroll-y>
  <view class="hero-card">
    <view class="hero-title">馆藏目录</view>
    <view class="hero-subtitle">按关键词、分类和可借状态筛选，联想词、热门搜索和最近搜索都保留。</view>
    <view class="toolbar">
      <input class="search-input" placeholder="搜索书名 / 作者 / ISBN" value="{{keyword}}" bindinput="onKeywordInput" confirm-type="search" bindconfirm="runSearch" />
      <view class="button-primary" bindtap="runSearch">搜索</view>
      <view class="button-ghost" bindtap="toggleAvailableOnly">{{availableOnly ? '仅看可借中' : '全部馆藏'}}</view>
      <view class="button-secondary" bindtap="goMy">我的中心</view>
      <view wx:if="{{keyword}}" class="button-secondary" bindtap="clearKeyword">清空关键词</view>
    </view>
  </view>

  <view class="panel">
    <view class="section-title">分类筛选</view>
    <view class="chip-row">
      <view class="pill-item {{selectedCategoryId === 0 ? 'pill-item--active' : ''}}" bindtap="pickCategory" data-category-id="0">全部</view>
      <view
        wx:for="{{catalog.categories || []}}"
        wx:key="categoryId"
        class="pill-item {{selectedCategoryId === item.categoryId ? 'pill-item--active' : ''}}"
        bindtap="pickCategory"
        data-category-id="{{item.categoryId}}"
      >
        {{item.name}}
      </view>
    </view>
  </view>

  <view wx:if="{{catalog && catalog.suggestions && catalog.suggestions.length}}" class="panel">
    <view class="section-title">联想词</view>
    <view class="chip-row">
      <view wx:for="{{catalog.suggestions}}" wx:key="*this" class="chip-primary" data-keyword="{{item}}" bindtap="applyKeyword">{{item}}</view>
    </view>
  </view>

  <view wx:if="{{catalog}}" class="panel">
    <view class="section-title">搜索提示</view>
    <view class="section-subtitle">热门搜索、联想词和最近搜索都会跟随后端真实数据刷新。</view>
    <view class="chip-row">
      <view wx:for="{{catalog.hotKeywords}}" wx:key="*this" class="chip" data-keyword="{{item}}" bindtap="applyKeyword">{{item}}</view>
    </view>
    <view class="divider"></view>
    <view class="chip-row">
      <view wx:for="{{catalog.searchHistory}}" wx:key="*this" class="tag-outline" data-keyword="{{item}}" bindtap="applyKeyword">{{item}}</view>
    </view>
  </view>

  <view class="panel">
    <view class="section-title">检索结果</view>
    <view class="section-subtitle">共 {{catalog && catalog.books ? catalog.books.length : 0}} 本</view>

    <view wx:if="{{loading}}" class="empty-card">正在加载馆藏目录...</view>
    <view wx:elif="{{errorMessage}}" class="empty-card danger-text">{{errorMessage}}</view>
    <view wx:elif="{{catalog && (!catalog.books || !catalog.books.length)}}" class="empty-card">当前筛选条件下没有命中图书，试试清空筛选或换个关键词。</view>

    <view
      wx:for="{{catalog.books || []}}"
      wx:key="bookId"
      class="list-card"
      data-book-id="{{item.bookId}}"
      bindtap="openDetail"
    >
      <image class="book-cover" src="{{item.coverUrl}}" mode="aspectFill"></image>
      <view class="book-info">
        <view class="book-title">{{item.title}}</view>
        <view class="book-meta">{{item.authorText}}</view>
        <view class="book-meta">{{item.publisherName}} · {{item.publishYear}}</view>
        <view class="chip-row" style="margin-top: 14rpx;">
          <view class="{{item.statusClass}}">{{item.statusText}}</view>
          <view class="chip">{{item.categoryName}}</view>
          <view wx:if="{{item.isFavorite}}" class="chip-primary">已收藏</view>
          <view wx:if="{{item.isBorrowed}}" class="chip-warning">借阅中</view>
          <view wx:if="{{item.isReserved}}" class="chip-danger">已预约</view>
        </view>
      </view>
    </view>
  </view>
</scroll-view>
