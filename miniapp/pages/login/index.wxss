page {
  min-height: 100vh;
  background: #f5f0e6;
}

.page {
  padding: 32rpx;
}

.card {
  margin-top: 80rpx;
  background: #fffaf2;
  border: 1rpx solid #ddceb8;
  border-radius: 24rpx;
  padding: 32rpx;
}

.title {
  color: #1f1a14;
  font-size: 40rpx;
  font-weight: 700;
}

.subtitle {
  color: #6f6559;
  font-size: 28rpx;
  margin-top: 12rpx;
  margin-bottom: 16rpx;
}

.notice {
  color: #0d8a72;
  background: #e3f5ef;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.input {
  height: 88rpx;
  border: 1rpx solid #ddceb8;
  border-radius: 16rpx;
  background: #ffffff;
  margin-bottom: 24rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.error {
  color: #b54035;
  font-size: 26rpx;
  margin-bottom: 24rpx;
}

.button {
  background: #0d8a72;
  color: #ffffff;
  border-radius: 16rpx;
}

.link-row {
  margin-top: 24rpx;
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.link {
  color: #0d8a72;
  font-size: 28rpx;
}
