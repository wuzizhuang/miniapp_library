<scroll-view class="page-shell" scroll-y>
  <view class="panel">
    <view class="section-title">馆藏速览</view>
    <view wx:if="{{loading}}" class="muted-text">正在加载首页数据...</view>
    <view wx:elif="{{errorMessage}}" class="danger-text">
      <view>{{errorMessage}}</view>
      <view class="inline-actions">
        <view class="button-secondary" bindtap="retryLoadHomePage">重新加载</view>
      </view>
    </view>
    <block wx:elif="{{homeData}}">
      <view class="stat-grid">
        <view class="stat-card" wx:for="{{homeData.heroStats}}" wx:key="label">
          <view class="stat-value">{{item.value}}</view>
          <view class="stat-label">{{item.label}}</view>
        </view>
      </view>
    </block>
  </view>

  <view wx:if="{{homeData}}" class="panel">
    <view class="toolbar-spread home-shelf-header">
      <view>
        <view class="section-title" style="margin-bottom: 8rpx;">热门书单</view>
        <view class="section-subtitle">最近最受欢迎的馆藏图书</view>
      </view>
      <view class="chip-primary">{{homeData.featuredBooks.length}} 本</view>
    </view>
    <view wx:if="{{homeData.featuredBooks.length}}">
      <view class="list-card" wx:for="{{homeData.featuredBooks}}" wx:key="id" data-book-id="{{item.id}}" bindtap="openBook">
        <image wx:if="{{item.cover}}" class="book-cover book-cover--small" src="{{item.cover}}" mode="aspectFill"></image>
        <view wx:else class="book-cover book-cover--small shelf-cover-placeholder">暂无封面</view>
        <view class="book-info">
          <view class="book-title">{{item.title}}</view>
          <view class="book-meta">{{item.author}}</view>
          <view class="chip-row">
            <view class="chip-primary">{{item.tag}}</view>
          </view>
        </view>
      </view>
    </view>
    <view wx:else class="muted-text">当前暂无热门书单，稍后再来看看。</view>
  </view>

  <view wx:if="{{homeData}}" class="panel">
    <view class="toolbar-spread home-shelf-header">
      <view>
        <view class="section-title" style="margin-bottom: 8rpx;">推荐书单</view>
        <view class="section-subtitle">结合首页推荐位整理出的优先阅读清单</view>
      </view>
      <view class="chip">{{homeData.recommendedBooks.length}} 本</view>
    </view>
    <view wx:if="{{homeData.recommendedBooks.length}}">
      <view class="list-card" wx:for="{{homeData.recommendedBooks}}" wx:key="id" data-book-id="{{item.id}}" bindtap="openBook">
        <image wx:if="{{item.cover}}" class="book-cover book-cover--small" src="{{item.cover}}" mode="aspectFill"></image>
        <view wx:else class="book-cover book-cover--small shelf-cover-placeholder">暂无封面</view>
        <view class="book-info">
          <view class="book-title">{{item.title}}</view>
          <view class="book-meta">{{item.author}}</view>
          <view class="chip-row">
            <view class="chip">{{item.tag}}</view>
          </view>
        </view>
      </view>
    </view>
    <view wx:else class="muted-text">当前暂无推荐书单，先去馆藏页检索看看。</view>
  </view>

  <view wx:if="{{homeData}}" class="panel">
    <view class="toolbar-spread home-shelf-header">
      <view>
        <view class="section-title" style="margin-bottom: 8rpx;">分类概览</view>
        <view class="section-subtitle">快速了解馆藏分布</view>
      </view>
      <view class="button-secondary home-shelf-action" bindtap="goBooks">去馆藏检索</view>
    </view>
    <view class="chip-row">
      <view class="chip" wx:for="{{homeData.categories}}" wx:key="categoryId">
        {{item.label}} {{item.count}}
      </view>
    </view>
  </view>
</scroll-view>
