<scroll-view class="page-shell" scroll-y>
  <view class="panel">
    <view class="toolbar-spread">
      <view>
        <view class="section-title">通知中心</view>
        <view class="section-subtitle">管理通知消息，快速定位待办事项</view>
      </view>
      <view class="button-row">
        <view class="{{actionKey === 'mark-all' ? 'button-secondary is-disabled' : 'button-secondary'}}" bindtap="markAllRead">
          {{actionKey === 'mark-all' ? '处理中...' : '全部已读'}}
        </view>
        <view class="{{actionKey === 'clear-read' ? 'button-ghost is-disabled' : 'button-ghost'}}" bindtap="clearRead">
          {{actionKey === 'clear-read' ? '处理中...' : '清空已读'}}
        </view>
      </view>
    </view>

    <view wx:if="{{loading}}" class="empty-card">正在加载通知...</view>
    <view wx:elif="{{errorMessage}}" class="empty-card danger-text">
      <view>{{errorMessage}}</view>
      <view class="inline-actions">
        <view class="button-secondary" bindtap="retryLoadNotifications">重新加载</view>
      </view>
    </view>
    <view wx:elif="{{!items.length}}" class="empty-card">当前没有通知消息。</view>

    <view wx:for="{{items}}" wx:key="notificationId" class="notice-card {{item.isRead ? '' : 'notice-card--unread'}}">
      <view class="toolbar-spread">
        <view class="notice-title">{{item.title}}</view>
        <view class="{{item.isRead ? 'chip' : 'chip-primary'}}">{{item.typeLabel}}</view>
      </view>
      <view class="notice-content">{{item.content}}</view>
      <view class="notice-meta">{{item.createDate}}</view>
      <view class="inline-actions">
        <view
          wx:if="{{!item.isRead}}"
          class="{{actionKey === 'mark-read-' + item.notificationId ? 'button-secondary is-disabled' : 'button-secondary'}}"
          data-notification-id="{{item.notificationId}}"
          bindtap="markRead"
        >
          {{actionKey === 'mark-read-' + item.notificationId ? '处理中...' : '标记已读'}}
        </view>
        <view wx:if="{{item.targetUrl}}" class="button-primary" data-notification-id="{{item.notificationId}}" bindtap="openTarget">{{item.actionLabel}}</view>
        <view
          class="{{actionKey === 'delete-' + item.notificationId ? 'button-ghost is-disabled' : 'button-ghost'}}"
          data-notification-id="{{item.notificationId}}"
          bindtap="deleteOne"
        >
          {{actionKey === 'delete-' + item.notificationId ? '处理中...' : '删除'}}
        </view>
      </view>
    </view>
  </view>
</scroll-view>
