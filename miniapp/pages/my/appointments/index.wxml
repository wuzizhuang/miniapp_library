<scroll-view class="page-shell" scroll-y scroll-into-view="{{highlightAnchor}}">
  <view class="hero-card">
    <view class="hero-title">服务预约</view>
    <view class="hero-subtitle">在线预约咨询、取书及图书馆各项服务</view>
  </view>

  <view class="panel">
    <view class="section-title">新建服务预约</view>
    <view class="field-stack">
      <view class="field-label">服务类型</view>
      <view class="chip-row">
        <view
          wx:for="{{serviceOptions}}"
          wx:key="value"
          class="pill-item {{serviceType === item.value ? 'pill-item--active' : ''}}"
          data-value="{{item.value}}"
          bindtap="pickService"
        >
          {{item.label}}
        </view>
      </view>

      <view class="field-label">办理方式</view>
      <view class="chip-row">
        <view
          wx:for="{{methodOptions}}"
          wx:key="value"
          class="pill-item {{method === item.value ? 'pill-item--active' : ''}}"
          data-value="{{item.value}}"
          bindtap="pickMethod"
        >
          {{item.label}}
        </view>
      </view>

      <view class="field-label">预约时间</view>
      <view class="picker-stack">
        <picker mode="date" value="{{appointmentDate}}" bindchange="onDateChange">
          <view class="picker-field">{{appointmentDate}}</view>
        </picker>
        <picker mode="time" value="{{appointmentTime}}" bindchange="onTimeChange">
          <view class="picker-field">{{appointmentTime}}</view>
        </picker>
      </view>


      <view class="helper-card">
        <view class="helper-card__title">温馨提示</view>
        <view class="helper-card__text">还书预约需选择借阅记录和归还地点，其他类型可直接提交。</view>
      </view>

      <view class="field-label">关联借阅</view>
      <picker mode="selector" range="{{loanPickerOptions}}" value="{{loanPickerIndex}}" bindchange="onLoanChange">
        <view class="picker-field {{loanPickerIndex === 0 ? 'picker-field--placeholder' : ''}}">
          {{selectedLoanLabel || '不关联借阅'}}
        </view>
      </picker>
      <view wx:if="{{serviceType === 'RETURN_BOOK'}}" class="field-helper-text">
        到馆还书必须选择一条“借阅中”或“已逾期”的记录。
      </view>
      <view wx:if="{{serviceType === 'RETURN_BOOK' && !activeLoans.length}}" class="danger-text">
        当前没有可关联的借阅记录，暂时无法提交到馆还书预约。
      </view>

      <block wx:if="{{serviceType === 'RETURN_BOOK'}}">
        <view class="field-label">归还地点</view>
        <picker mode="selector" range="{{returnLocationPickerOptions}}" value="{{returnLocationPickerIndex}}" bindchange="onReturnLocationChange">
          <view class="picker-field {{!returnLocation ? 'picker-field--placeholder' : ''}}">
            {{selectedReturnLocationLabel || '请选择归还地点'}}
          </view>
        </picker>
        <view wx:if="{{selectedReturnLocationDescription}}" class="field-helper-text">
          {{selectedReturnLocationDescription}}
        </view>
      </block>

      <view class="field-label">备注</view>
      <textarea class="textarea" value="{{notes}}" data-field="notes" bindinput="onFieldInput" placeholder="填写到馆说明、咨询主题或特殊需求"></textarea>

      <view class="{{submitting ? 'button-primary is-disabled' : 'button-primary'}}" bindtap="createAppointment">
        {{submitting ? '提交中...' : '提交预约'}}
      </view>
    </view>
  </view>

  <view class="panel">
    <view class="section-title">我的服务预约</view>
    <view wx:if="{{loading}}" class="empty-card">正在加载服务预约...</view>
    <view wx:elif="{{errorMessage}}" class="empty-card danger-text">
      <view>{{errorMessage}}</view>
      <view class="inline-actions">
        <view class="button-secondary" bindtap="retryLoadAppointments">重新加载</view>
      </view>
    </view>
    <view wx:elif="{{!items.length}}" class="empty-card">当前没有服务预约记录。</view>

    <view
      wx:for="{{items}}"
      wx:key="appointmentId"
      id="appointment-{{item.appointmentId}}"
      class="notice-card {{item.isHighlighted ? 'notice-card--highlight' : ''}}"
    >
      <view class="toolbar-spread">
        <view class="notice-title">{{item.serviceLabel}}</view>
        <view class="{{item.statusClass}}">{{item.statusLabel}}</view>
      </view>
      <view class="notice-content">方式：{{item.methodLabel}}</view>
      <view class="notice-content">时间：{{item.timeLabel}}</view>
      <view wx:if="{{item.bookTitle}}" class="notice-content">图书：{{item.bookTitle}}</view>
      <view wx:if="{{item.returnLocation}}" class="notice-content">归还地点：{{item.returnLocation}}</view>
      <view wx:if="{{item.notes}}" class="notice-content">备注：{{item.notes}}</view>
      <view wx:if="{{item.status === 'PENDING'}}" class="inline-actions">
        <view
          class="{{cancellingAppointmentId === item.appointmentId ? 'button-secondary is-disabled' : 'button-secondary'}}"
          bindtap="cancelAppointment"
          data-appointment-id="{{item.appointmentId}}"
        >
          {{cancellingAppointmentId === item.appointmentId ? '取消中...' : '取消预约'}}
        </view>
      </view>
    </view>
  </view>
</scroll-view>
